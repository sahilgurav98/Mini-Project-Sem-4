<%- include('../layouts/header') %>

    <style>
        /* Modern Dark Theme Palette */
        :root {
            --shadow-accent: #7c3aed;
            --shadow-accent-hover: #6d28d9;
            --shadow-bg: #0b0f19;
            --shadow-card: #111827;
            --shadow-text: #f8fafc;
            --shadow-muted: #94a3b8;
            --shadow-border: rgba(255, 255, 255, 0.08);
            --admin-accent: #ef4444;
            --admin-accent-hover: #dc2626;
            --ai-accent: #3b82f6;
            --success-glow: rgba(16, 185, 129, 0.15);
            --danger-glow: rgba(239, 68, 68, 0.15);
            --info-glow: rgba(59, 130, 246, 0.15);
            --purple-glow: rgba(124, 58, 237, 0.15);
        }

        body {
            background-color: var(--shadow-bg);
            color: var(--shadow-text) !important;
            --bs-body-bg: var(--shadow-bg);
            --bs-body-color: var(--shadow-text);
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
        }

        /* --- Global Card Styling --- */
        .admin-card {
            background-color: var(--shadow-card);
            color: var(--shadow-text);
            border-radius: 1.25rem;
            border: 1px solid var(--shadow-border);
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.4);
            overflow: hidden;
            margin-bottom: 1.5rem;
            transition: box-shadow 0.3s ease;
        }
        .admin-card .card-header,
        .admin-card .card-body,
        .analytics-card,
        .menu-item-card,
        .table-custom tbody tr {
            color: var(--shadow-text);
        }
        .admin-card:hover {
            box-shadow: 0 15px 50px rgba(0, 0, 0, 0.5);
        }

        .admin-header-bg {
            background: rgba(255, 255, 255, 0.02);
            border-bottom: 1px solid var(--shadow-border);
            padding: 1.25rem 1.5rem;
        }

        .ai-header-bg {
            background: linear-gradient(135deg, rgba(30, 58, 138, 0.3), transparent);
            border-bottom: 1px solid rgba(59, 130, 246, 0.3);
            padding: 1.25rem 1.5rem;
        }

        /* --- Analytics Cards (Top Row) --- */
        .analytics-card {
            background: linear-gradient(145deg, rgba(30, 41, 59, 0.4), rgba(15, 23, 42, 0.6));
            border: 1px solid var(--shadow-border);
            border-radius: 1.25rem;
            padding: 1.5rem;
            height: 100%;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }
        .analytics-card:hover {
            transform: translateY(-5px);
            background: linear-gradient(145deg, rgba(30, 41, 59, 0.6), rgba(15, 23, 42, 0.8));
        }
        /* Top border accents for analytics cards */
        .ac-purple { border-top: 3px solid var(--shadow-accent); box-shadow: 0 8px 30px var(--purple-glow); }
        .ac-info { border-top: 3px solid var(--ai-accent); box-shadow: 0 8px 30px var(--info-glow); }
        .ac-success { border-top: 3px solid #10b981; box-shadow: 0 8px 30px var(--success-glow); }
        .ac-danger { border-top: 3px solid var(--admin-accent); box-shadow: 0 8px 30px var(--danger-glow); }

        .analytics-value {
            font-size: clamp(2rem, 4vw, 2.5rem);
            font-weight: 800;
            color: #fff;
            line-height: 1.2;
            letter-spacing: -1px;
        }

        /* --- Forms & Inputs --- */
        .form-control, .form-select, .input-group-text {
            background-color: rgba(0, 0, 0, 0.25) !important;
            border: 1px solid rgba(255, 255, 255, 0.1) !important;
            color: #ffffff !important;
            border-radius: 0.5rem;
            padding: 0.6rem 1rem;
        }
        .form-control:focus, .form-select:focus {
            background-color: rgba(0, 0, 0, 0.4) !important;
            box-shadow: 0 0 0 0.25rem rgba(220, 38, 38, 0.15) !important;
            border-color: var(--admin-accent) !important;
        }
        .ai-input:focus {
            box-shadow: 0 0 0 0.25rem rgba(59, 130, 246, 0.15) !important;
            border-color: var(--ai-accent) !important;
        }
        .file-input-dark {
            color: #e2e8f0 !important;
            background: linear-gradient(135deg, rgba(15, 23, 42, 0.92), rgba(30, 41, 59, 0.82)) !important;
            border: 1px solid rgba(59, 130, 246, 0.22) !important;
            padding: 0.4rem !important;
        }
        .file-input-dark::-webkit-file-upload-button {
            margin-right: 0.9rem;
            border: 0;
            border-radius: 0.7rem;
            padding: 0.72rem 1rem;
            background: linear-gradient(135deg, rgba(59, 130, 246, 0.95), rgba(37, 99, 235, 0.95));
            color: white;
            font-weight: 700;
            letter-spacing: 0.02em;
            cursor: pointer;
        }
        .file-input-dark::file-selector-button {
            margin-right: 0.9rem;
            border: 0;
            border-radius: 0.7rem;
            padding: 0.72rem 1rem;
            background: linear-gradient(135deg, rgba(59, 130, 246, 0.95), rgba(37, 99, 235, 0.95));
            color: white;
            font-weight: 700;
            letter-spacing: 0.02em;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        .file-input-dark:hover::file-selector-button {
            transform: translateY(-1px);
            box-shadow: 0 8px 18px rgba(59, 130, 246, 0.28);
        }
        .training-pulse {
            position: relative;
            overflow: hidden;
        }
        .training-pulse::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg, transparent, rgba(59, 130, 246, 0.18), transparent);
            transform: translateX(-100%);
            animation: trainingSweep 1.3s linear infinite;
        }
        @keyframes trainingSweep {
            to { transform: translateX(100%); }
        }
        .form-control::placeholder { color: rgba(255, 255, 255, 0.4) !important; }
        .form-select option { background-color: #1e293b !important; color: #ffffff !important; }

        /* --- Tables --- */
        .order-table-scroll {
            max-height: 800px;
            overflow-y: auto;
        }
        .order-table-scroll::-webkit-scrollbar { width: 6px; }
        .order-table-scroll::-webkit-scrollbar-track { background: rgba(0, 0, 0, 0.2); }
        .order-table-scroll::-webkit-scrollbar-thumb { background-color: rgba(255, 255, 255, 0.15); border-radius: 10px; }

        .table-custom {
            color: var(--shadow-text) !important;
            margin-bottom: 0;
            --bs-table-bg: transparent;
            --bs-table-hover-bg: rgba(255, 255, 255, 0.02);
        }
        .table-custom thead th {
            background-color: rgba(0, 0, 0, 0.4);
            color: var(--shadow-muted) !important;
            border-bottom: 1px solid var(--shadow-border);
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 1px;
            padding: 1rem 1.5rem;
        }
        .table-custom td {
            vertical-align: middle;
            border-bottom: 1px solid rgba(255, 255, 255, 0.03);
            padding: 1.25rem 1.5rem;
        }

        /* --- Menu Items Cards (Replaces List Group) --- */
        .menu-list-container {
            max-height: 600px;
            overflow-y: auto;
            padding-right: 5px;
        }
        .menu-list-container::-webkit-scrollbar { width: 4px; }
        .menu-list-container::-webkit-scrollbar-track { background: transparent; }
        .menu-list-container::-webkit-scrollbar-thumb { background-color: rgba(255, 255, 255, 0.1); border-radius: 10px; }

        .menu-item-card {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid var(--shadow-border);
            border-radius: 1rem;
            padding: 1rem;
            margin-bottom: 0.75rem;
            transition: all 0.2s ease;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .menu-item-card:hover {
            background: rgba(255, 255, 255, 0.04);
            border-color: rgba(255, 255, 255, 0.15);
        }

        /* --- Badges & Images --- */
        .badge-status {
            padding: 0.6em 1em;
            border-radius: 20px;
            letter-spacing: 0.5px;
            font-weight: 700;
            font-size: 0.75rem;
            text-transform: uppercase;
        }
        .product-thumb {
            width: 50px;
            height: 50px;
            border-radius: 0.75rem;
            object-fit: cover;
            border: 1px solid rgba(255, 255, 255, 0.1);
            background: rgba(0, 0, 0, 0.3);
        }
        .product-thumb-fallback {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: var(--shadow-muted);
            font-size: 1.25rem;
        }

        /* --- Buttons --- */
        .btn { transition: all 0.2s ease; font-weight: 600; letter-spacing: 0.5px; }
        .btn:hover { transform: translateY(-1px); }
        
        .btn-admin { background-color: var(--admin-accent); border-color: var(--admin-accent); color: white; }
        .btn-admin:hover { background-color: var(--admin-accent-hover); color: white; }
        
        .btn-ai { background-color: var(--ai-accent); border-color: var(--ai-accent); color: white; }
        .btn-ai:hover { background-color: #2563eb; color: white; box-shadow: 0 4px 12px var(--info-glow); }

        .btn-warning-soft { background-color: rgba(245, 158, 11, 0.1); color: #fbbf24; border: 1px solid rgba(245, 158, 11, 0.3); }
        .btn-warning-soft:hover { background-color: rgba(245, 158, 11, 0.2); color: #fff; }

        .btn-ai-download { background-color: rgba(56, 189, 248, 0.1); color: #38bdf8; border: 1px solid rgba(56, 189, 248, 0.3); }
        .btn-ai-download:hover { background-color: rgba(56, 189, 248, 0.2); color: #fff; border-color: #38bdf8; }

        /* Typography */
        .text-success-custom { color: #34d399 !important; }
        .text-muted { color: var(--shadow-muted) !important; }
        
        /* Mobile fixes */
        @media (max-width: 768px) {
            .action-buttons-wrap { flex-wrap: wrap; justify-content: flex-start !important; }
            .action-buttons-wrap form { flex-grow: 1; }
            .action-buttons-wrap button { width: 100%; }
        }
    </style>

    <div class="container-fluid py-4 mb-5">

        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between mb-4 pb-3 border-bottom gap-3"
            style="border-color: var(--shadow-border) !important;">
            <div class="d-flex align-items-center">
                <div class="p-2 bg-danger bg-opacity-10 rounded-3 me-3 border border-danger border-opacity-25">
                    <i class="fa-solid fa-server fa-2x text-danger"></i>
                </div>
                <h2 class="mb-0 fw-bold text-white tracking-tight">Admin Dashboard</h2>
            </div>
            
            <div class="d-flex align-items-center bg-dark bg-opacity-50 p-2 rounded-4 border" style="border-color: rgba(255,255,255,0.05);">
                <div id="event-status-badge">
                    <% if(eventActive) { %>
                        <span class="badge bg-success bg-opacity-25 text-success border border-success px-3 py-2 fw-bold rounded-pill me-3" style="letter-spacing: 1px;">
                            <i class="fa-solid fa-bolt me-1"></i> EVENT ACTIVE
                        </span>
                    <% } else { %>
                        <span class="badge bg-secondary bg-opacity-25 text-secondary border border-secondary px-3 py-2 fw-bold rounded-pill me-3" style="letter-spacing: 1px;">
                            <i class="fa-solid fa-moon me-1"></i> EVENT OFFLINE
                        </span>
                    <% } %>
                </div>
                <form action="/admin/toggle-event" method="POST" class="m-0">
                    <button type="submit" class="btn btn-sm btn-outline-light rounded-pill px-3 shadow-sm fw-bold">Toggle Mode</button>
                </form>
            </div>
        </div>

        <div id="analytics-summary" class="row g-3 g-lg-4 mb-4">
            <div class="col-sm-6 col-xl-3">
                <div class="analytics-card ac-purple">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="small text-uppercase text-muted fw-bold mb-2">Total Orders</div>
                            <div class="analytics-value"><%= analytics.totalOrders %></div>
                        </div>
                        <div class="p-2 bg-purple rounded-3 bg-opacity-10 text-purple"><i class="fa-solid fa-receipt fs-4" style="color: var(--shadow-accent);"></i></div>
                    </div>
                    <div class="small text-muted mt-3 pt-3 border-top" style="border-color: rgba(255,255,255,0.05) !important;">All orders recorded</div>
                </div>
            </div>
            
            <div class="col-sm-6 col-xl-3">
                <div class="analytics-card ac-info">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="small text-uppercase text-muted fw-bold mb-2">Active Queue</div>
                            <div class="analytics-value"><%= activeQueueCount %> <span class="fs-5 text-muted">/ <%= queueLimit %></span></div>
                        </div>
                        <div class="p-2 bg-info rounded-3 bg-opacity-10 text-info"><i class="fa-solid fa-users fs-4"></i></div>
                    </div>
                    <div class="small mt-3 pt-3 border-top <%= activeQueueCount < queueLimit ? 'text-info' : 'text-danger' %>" style="border-color: rgba(255,255,255,0.05) !important;">
                        <i class="fa-solid <%= activeQueueCount < queueLimit ? 'fa-door-open' : 'fa-lock' %> me-1"></i> <%= activeQueueCount < queueLimit ? 'Queue accepting orders' : 'Queue is currently full' %>
                    </div>
                </div>
            </div>
            
            <div class="col-sm-6 col-xl-3">
                <div class="analytics-card ac-success">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="small text-uppercase text-muted fw-bold mb-2">Paid Revenue</div>
                            <div class="analytics-value text-success-custom">₹<%= analytics.totalRevenue %></div>
                        </div>
                        <div class="p-2 bg-success rounded-3 bg-opacity-10 text-success"><i class="fa-solid fa-wallet fs-4"></i></div>
                    </div>
                    <div class="small text-muted mt-3 pt-3 border-top" style="border-color: rgba(255,255,255,0.05) !important;">From <%= analytics.paidOrders %> paid orders</div>
                </div>
            </div>
            
            <div class="col-sm-6 col-xl-3">
                <div class="analytics-card ac-danger">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="small text-uppercase text-muted fw-bold mb-2">Success Rate</div>
                            <div class="analytics-value text-white">
                                <%= analytics.totalOrders ? Math.round((analytics.fulfilledOrders / analytics.totalOrders) * 100) : 0 %>%
                            </div>
                        </div>
                        <div class="p-2 bg-danger rounded-3 bg-opacity-10 text-danger"><i class="fa-solid fa-chart-pie fs-4"></i></div>
                    </div>
                    <div class="small mt-3 pt-3 border-top d-flex justify-content-between" style="border-color: rgba(255,255,255,0.05) !important;">
                        <span class="text-success"><i class="fa-solid fa-check me-1"></i><%= analytics.fulfilledOrders %> Done</span>
                        <span class="text-danger"><i class="fa-solid fa-xmark me-1"></i><%= analytics.rejectedOrders %> Rej</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card admin-card">
            <div class="card-header admin-header-bg d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold text-white"><i class="fa-solid fa-fire me-2 text-warning"></i>Analytics Snapshot</h5>
                <span class="small text-muted d-none d-sm-inline">Top selling items and queue health</span>
            </div>
            <div class="card-body p-4">
                <div class="row g-5">
                    <div class="col-lg-7">
                        <label class="small text-muted text-uppercase fw-bold mb-3"><i class="fa-solid fa-ranking-star me-2"></i>Top Selling Items</label>
                        <div id="top-selling-items" class="d-flex flex-column gap-2">
                            <% if (analytics.topItems.length === 0) { %>
                                <div class="menu-item-card justify-content-center text-muted py-4">No order data yet.</div>
                            <% } %>
                            <% analytics.topItems.forEach((item, index) => { %>
                                <div class="menu-item-card p-3">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="bg-dark rounded-circle d-flex align-items-center justify-content-center border border-secondary" style="width: 32px; height: 32px; color: var(--shadow-muted);"><%= index + 1 %></div>
                                        <div>
                                            <div class="fw-bold text-white fs-6"><%= item.name %></div>
                                            <div class="small text-muted"><%= item.orders %> individual orders</div>
                                        </div>
                                    </div>
                                    <div class="text-end">
                                        <div class="fw-bold text-success-custom bg-success bg-opacity-10 px-3 py-1 rounded-pill border border-success border-opacity-25"><%= item.quantity %> units</div>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                    <div class="col-lg-5">
                        <label class="small text-muted text-uppercase fw-bold mb-3"><i class="fa-solid fa-heart-pulse me-2"></i>Quick Health</label>
                        <div id="quick-health-panel" class="analytics-card" style="border-top: none;">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="text-muted fw-bold">Queue Capacity</span>
                                <span class="fw-bold text-white fs-5"><%= activeQueueCount %> / <%= queueLimit %></span>
                            </div>
                            <div class="progress mb-4 rounded-pill" style="height: 8px; background-color: rgba(255,255,255,0.08);">
                                <div class="progress-bar rounded-pill <%= activeQueueCount < queueLimit ? 'bg-success' : 'bg-danger' %>" style="width: <%= Math.min((activeQueueCount / queueLimit) * 100, 100) %>%"></div>
                            </div>
                            
                            <hr style="border-color: rgba(255,255,255,0.1);">
                            
                            <div class="d-flex justify-content-between align-items-center mt-3 mb-2">
                                <span class="text-muted fw-bold">Paid Conversion</span>
                                <span class="fw-bold text-info fs-5"><%= analytics.totalOrders ? Math.round((analytics.paidOrders / analytics.totalOrders) * 100) : 0 %>%</span>
                            </div>
                            
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <span class="text-muted fw-bold">Fulfillment Success</span>
                                <span class="fw-bold text-success-custom fs-5"><%= analytics.totalOrders ? Math.round((analytics.fulfilledOrders / analytics.totalOrders) * 100) : 0 %>%</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card admin-card border-primary border-opacity-25">
            <div class="card-header ai-header-bg text-white d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3">
                <h5 class="mb-0 fw-bold d-flex align-items-center text-info">
                    <i class="fa-solid fa-brain me-2"></i> AI Demand Predictor (FNN)
                </h5>

                <div id="ai-status-badges" class="d-flex align-items-center flex-wrap gap-2">
                    <% if(isModelTrained) { %>
                        <span class="badge bg-success bg-opacity-25 text-success-custom border border-success badge-status">
                            <i class="fa-solid fa-circle-check me-1"></i> MODEL ONLINE
                        </span>
                        <% if(activeMae !== null && activeMae !== undefined) { %>
                        <span class="badge bg-info bg-opacity-25 text-info border border-info badge-status">
                            MAE: <%= parseFloat(activeMae).toFixed(3) %>
                        </span>
                        <% } %>
                    <% } else { %>
                        <span class="badge bg-danger bg-opacity-25 text-danger border border-danger badge-status">
                            <i class="fa-solid fa-circle-xmark me-1"></i> OFFLINE (NEEDS DATA)
                        </span>
                    <% } %>
                </div>
            </div>

            <div class="card-body p-4 p-lg-5">
                <div id="ai-feedback-area">
                    <% if(error) { %>
                        <div class="alert alert-danger d-flex align-items-center rounded-3 shadow-sm border-0 bg-dark text-danger mb-4">
                            <i class="fa-solid fa-triangle-exclamation me-3 fs-5"></i>
                            <div><%= error %></div>
                        </div>
                    <% } %>

                    <% if(isModelTrained && !prediction) { %>
                        <div class="alert alert-success d-flex align-items-center rounded-3 shadow-sm border border-success border-opacity-25 bg-dark text-success-custom mb-5 p-3">
                            <div class="bg-success bg-opacity-25 p-2 rounded-circle me-3"><i class="fa-solid fa-microchip fs-5"></i></div>
                            <div>
                                <strong class="d-block">Model Active</strong>
                                <span>AI Model successfully trained and loaded into server memory. Ready for predictions.</span>
                            </div>
                        </div>
                    <% } %>
                </div>

                <div class="row g-5">
                    <div class="col-lg-5 border-end border-secondary pe-lg-5" style="border-color: rgba(255,255,255,0.05) !important;">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h6 class="fw-bold text-uppercase text-white mb-0">
                                <span class="text-muted me-2">1.</span> Train Model
                            </h6>
                            <a href="/admin/ml/download-data" class="btn btn-sm btn-ai-download shadow-sm fw-bold rounded-pill px-3">
                                <i class="fa-solid fa-download me-1"></i> Get CSV
                            </a>
                        </div>

                        <form id="train-model-form" action="/admin/ml/train" method="POST" enctype="multipart/form-data" class="bg-dark bg-opacity-50 p-4 rounded-4 border border-secondary border-opacity-50">
                            <div class="mb-3">
                                <label class="small text-muted fw-bold mb-2">Upload Training Dataset (.csv / .xlsx)</label>
                                <input type="file" name="dataset" class="form-control ai-input file-input-dark" accept=".csv, .xlsx" required>
                            </div>
                            <button id="train-model-button" class="btn btn-ai fw-bold w-100 rounded-3 py-2">
                                <i class="fa-solid fa-gears me-2"></i> INITIATE TRAINING
                            </button>
                            <div class="small text-muted mt-3 text-center">
                                <i class="fa-solid fa-circle-info me-1 text-info"></i> Download recent CSV, edit 'Events', and upload.
                            </div>
                        </form>
                    </div>

                    <div class="col-lg-7 ps-lg-5">
                        <h6 class="fw-bold text-uppercase text-white mb-4">
                            <span class="text-muted me-2">2.</span> Run Prediction
                        </h6>

                        <form action="/admin/ml/predict" method="POST" class="row g-3 bg-dark bg-opacity-50 p-4 rounded-4 border border-secondary border-opacity-50">
                            <div class="col-md-4">
                                <label class="small text-muted fw-bold mb-1">Day</label>
                                <select name="day" class="form-select ai-input border-0 shadow-sm">
                                    <option>Mon</option><option>Tue</option><option>Wed</option><option>Thu</option><option>Fri</option><option>Sat</option><option>Sun</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="small text-muted fw-bold mb-1">Time</label>
                                <select name="time" class="form-select ai-input border-0 shadow-sm">
                                    <option>Breakfast</option><option>Lunch</option><option>Dinner</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="small text-muted fw-bold mb-1">Item Name</label>
                                <input type="text" name="itemName" placeholder="e.g. Rice" class="form-control ai-input border-0 shadow-sm" required>
                            </div>
                            
                            <div class="col-md-4">
                                <label class="small text-muted fw-bold mb-1">Price (₹)</label>
