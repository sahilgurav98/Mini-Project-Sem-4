                                </div>
                            <% }) %>
                        </div>
                        
                    </div>
                </div>
            </div>
        </div>
    </div>

    <audio id="notificationSound" src="https://assets.mixkit.co/active_storage/sfx/2869/2869-preview.mp3" preload="auto"></audio>
    <script id="admin-dashboard-data" type="application/json"><%- JSON.stringify({
        eventActive,
        products,
        orders,
        prediction,
        error,
        isModelTrained,
        activeMae,
        queueLimit,
        activeQueueCount,
        analytics
    }) %></script>

    <script>
        // --- Live Order Polling System ---
        let latestOrderId = null; 
        let isFirstLoad = true;

        setInterval(fetchLiveOrders, 3000);

        async function fetchLiveOrders() {
            try {
                const response = await fetch('/admin/api/orders');
                const orders = await response.json();

                const tbody = document.getElementById('live-orders-table');
                if (!tbody) return;

                if (orders.length > 0) {
                    const currentLatest = orders[0]._id; 

                    if (!isFirstLoad && latestOrderId !== currentLatest) {
                        document.getElementById('notificationSound').play().catch(e => console.log("Audio interaction blocked"));
                    }
                    latestOrderId = currentLatest;
                }
                isFirstLoad = false;

                let html = '';

                orders.forEach(o => {
                    let itemsHtml = `
                    <div class="bg-dark bg-opacity-50 p-2 rounded-3 border border-secondary border-opacity-25 mb-2">
                        <ul class="mb-0 small ps-3 text-white">`;
                    o.items.forEach(i => {
                        itemsHtml += `<li><span class="text-danger fw-bold me-1">${i.quantity}x</span> ${i.itemName}</li>`;
                    });
                    itemsHtml += `
                        </ul>
                    </div>
                    <div class="fw-bold text-success-custom fs-5">₹${o.totalAmount}</div>`;

                    const badgeClass =
                        o.status === 'Fulfilled'
                            ? 'bg-success text-white'
                            : o.status === 'Rejected'
                                ? 'bg-danger text-white'
                                : o.status === 'Cancelled'
                                    ? 'bg-secondary text-white'
                                    : 'bg-warning text-dark';
                    let statusBadge = `<span class="badge ${badgeClass} w-100 rounded-pill px-3 py-2 shadow-sm">${o.status}</span>`;
                    
                    if (o.couponCode && o.status !== 'Fulfilled') {
                        statusBadge += `
                        <div class="mt-2 badge border border-info text-info bg-info bg-opacity-10 w-100 py-2 d-flex align-items-center justify-content-center" style="font-size: 0.85rem; letter-spacing: 1px;">
                            <i class="fa-solid fa-ticket me-2"></i> ${o.couponCode}
                        </div>`;
                    }

                    let actionButtons = '<div class="d-flex justify-content-end gap-2 action-buttons-wrap">';

                    if (o.status !== 'Fulfilled' && o.status !== 'Rejected' && o.status !== 'Cancelled') {
                        if (o.paymentStatus !== 'Paid') {
                            actionButtons += `
                                <form action="/admin/order/coupon/${o._id}" method="POST" class="m-0 flex-grow-1 flex-sm-grow-0">
                                    <button class="btn btn-sm btn-info shadow-sm rounded-3 text-dark fw-bold w-100 h-100" title="Payment Received - Issue Coupon">
                                        <i class="fa-solid fa-ticket"></i> ISSUE
                                    </button>
                                </form>`;
                        } else {
                            actionButtons += `
                                <form action="/admin/order/fulfill/${o._id}" method="POST" class="m-0 flex-grow-1 flex-sm-grow-0">
                                    <button class="btn btn-sm btn-success shadow-sm rounded-3 fw-bold w-100 h-100" title="Mark as Fulfilled">
                                        <i class="fa-solid fa-check"></i> FULFILL
                                    </button>
                                </form>`;
                        }
                        actionButtons += `
                            <form action="/admin/order/reject/${o._id}" method="POST" class="m-0">
                                <button class="btn btn-sm btn-warning-soft shadow-sm rounded-3 fw-bold h-100" title="Reject Order">
                                    <i class="fa-solid fa-ban"></i>
                                </button>
                            </form>`;
                    }

                    actionButtons += `
                        <form action="/admin/order/delete/${o._id}" method="POST" class="m-0">
                            <button class="btn btn-sm btn-outline-danger shadow-sm rounded-3 h-100" title="Delete Log">
                                <i class="fa-solid fa-trash-can"></i>
                            </button>
                        </form>
                    </div>`;

                    html += `
                    <tr>
                        <td class="ps-4">
                            <strong class="text-white fs-6">${o.studentName}</strong><br>
                            <span class="small text-muted">${o.year} | ${o.branch}</span><br>
                            <span class="badge bg-dark border border-secondary text-muted mt-1 px-2 py-1">Reg: ${o.regNo}</span>
                        </td>
                        <td>${itemsHtml}</td>
                        <td class="text-center" style="width: 140px;">${statusBadge}</td>
                        <td class="pe-4">${actionButtons}</td>
                    </tr>`;
                });

                tbody.innerHTML = html;

            } catch (error) {
                console.error("Error fetching live orders:", error);
            }
        }
    </script>

    <script>
        const dashboardDataEl = document.getElementById('admin-dashboard-data');
        let dashboardState = dashboardDataEl ? JSON.parse(dashboardDataEl.textContent) : null;
        const rupee = '\u20B9';

        function escapeHtml(value) {
            return String(value ?? '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        function getStatusBadgeClass(status) {
            if (status === 'Fulfilled') return 'bg-success text-white';
            if (status === 'Rejected') return 'bg-danger text-white';
            if (status === 'Cancelled') return 'bg-secondary text-white';
            return 'bg-warning text-dark';
        }

        function renderEventBadge(eventActive) {
            const badge = document.getElementById('event-status-badge');
            if (!badge) return;

            badge.innerHTML = eventActive
                ? `<span class="badge bg-success bg-opacity-25 text-success border border-success px-3 py-2 fw-bold rounded-pill me-3" style="letter-spacing: 1px;"><i class="fa-solid fa-bolt me-1"></i> EVENT ACTIVE</span>`
                : `<span class="badge bg-secondary bg-opacity-25 text-secondary border border-secondary px-3 py-2 fw-bold rounded-pill me-3" style="letter-spacing: 1px;"><i class="fa-solid fa-moon me-1"></i> EVENT OFFLINE</span>`;
        }

        function renderAnalyticsSummary(data) {
            const container = document.getElementById('analytics-summary');
            if (!container) return;

            const queueOk = data.activeQueueCount < data.queueLimit;
            const successRate = data.analytics.totalOrders ? Math.round((data.analytics.fulfilledOrders / data.analytics.totalOrders) * 100) : 0;

            container.innerHTML = `
                <div class="col-sm-6 col-xl-3"><div class="analytics-card ac-purple"><div class="d-flex justify-content-between align-items-start"><div><div class="small text-uppercase text-muted fw-bold mb-2">Total Orders</div><div class="analytics-value">${data.analytics.totalOrders}</div></div><div class="p-2 bg-purple rounded-3 bg-opacity-10 text-purple"><i class="fa-solid fa-receipt fs-4" style="color: var(--shadow-accent);"></i></div></div><div class="small text-muted mt-3 pt-3 border-top" style="border-color: rgba(255,255,255,0.05) !important;">All orders recorded</div></div></div>
                <div class="col-sm-6 col-xl-3"><div class="analytics-card ac-info"><div class="d-flex justify-content-between align-items-start"><div><div class="small text-uppercase text-muted fw-bold mb-2">Active Queue</div><div class="analytics-value">${data.activeQueueCount} <span class="fs-5 text-muted">/ ${data.queueLimit}</span></div></div><div class="p-2 bg-info rounded-3 bg-opacity-10 text-info"><i class="fa-solid fa-users fs-4"></i></div></div><div class="small mt-3 pt-3 border-top ${queueOk ? 'text-info' : 'text-danger'}" style="border-color: rgba(255,255,255,0.05) !important;"><i class="fa-solid ${queueOk ? 'fa-door-open' : 'fa-lock'} me-1"></i> ${queueOk ? 'Queue accepting orders' : 'Queue is currently full'}</div></div></div>
                <div class="col-sm-6 col-xl-3"><div class="analytics-card ac-success"><div class="d-flex justify-content-between align-items-start"><div><div class="small text-uppercase text-muted fw-bold mb-2">Paid Revenue</div><div class="analytics-value text-success-custom">${rupee}${data.analytics.totalRevenue}</div></div><div class="p-2 bg-success rounded-3 bg-opacity-10 text-success"><i class="fa-solid fa-wallet fs-4"></i></div></div><div class="small text-muted mt-3 pt-3 border-top" style="border-color: rgba(255,255,255,0.05) !important;">From ${data.analytics.paidOrders} paid orders</div></div></div>
                <div class="col-sm-6 col-xl-3"><div class="analytics-card ac-danger"><div class="d-flex justify-content-between align-items-start"><div><div class="small text-uppercase text-muted fw-bold mb-2">Success Rate</div><div class="analytics-value text-white">${successRate}%</div></div><div class="p-2 bg-danger rounded-3 bg-opacity-10 text-danger"><i class="fa-solid fa-chart-pie fs-4"></i></div></div><div class="small mt-3 pt-3 border-top d-flex justify-content-between" style="border-color: rgba(255,255,255,0.05) !important;"><span class="text-success"><i class="fa-solid fa-check me-1"></i>${data.analytics.fulfilledOrders} Done</span><span class="text-danger"><i class="fa-solid fa-xmark me-1"></i>${data.analytics.rejectedOrders} Rej</span></div></div></div>`;
        }

        function renderTopItems(data) {
            const container = document.getElementById('top-selling-items');
            if (!container) return;

            if (!data.analytics.topItems.length) {
                container.innerHTML = '<div class="menu-item-card justify-content-center text-muted py-4">No order data yet.</div>';
                return;
            }

            container.innerHTML = data.analytics.topItems.map((item, index) => `
                <div class="menu-item-card p-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-dark rounded-circle d-flex align-items-center justify-content-center border border-secondary" style="width: 32px; height: 32px; color: var(--shadow-muted);">${index + 1}</div>
                        <div><div class="fw-bold text-white fs-6">${escapeHtml(item.name)}</div><div class="small text-muted">${item.orders} individual orders</div></div>
                    </div>
                    <div class="text-end"><div class="fw-bold text-success-custom bg-success bg-opacity-10 px-3 py-1 rounded-pill border border-success border-opacity-25">${item.quantity} units</div></div>
                </div>`).join('');
        }

        function renderQuickHealth(data) {
            const container = document.getElementById('quick-health-panel');
            if (!container) return;

            const queuePercent = data.queueLimit ? Math.min((data.activeQueueCount / data.queueLimit) * 100, 100) : 0;
            const paidConversion = data.analytics.totalOrders ? Math.round((data.analytics.paidOrders / data.analytics.totalOrders) * 100) : 0;
            const fulfillmentSuccess = data.analytics.totalOrders ? Math.round((data.analytics.fulfilledOrders / data.analytics.totalOrders) * 100) : 0;

            container.innerHTML = `
                <div class="d-flex justify-content-between align-items-center mb-2"><span class="text-muted fw-bold">Queue Capacity</span><span class="fw-bold text-white fs-5">${data.activeQueueCount} / ${data.queueLimit}</span></div>
                <div class="progress mb-4 rounded-pill" style="height: 8px; background-color: rgba(255,255,255,0.08);"><div class="progress-bar rounded-pill ${data.activeQueueCount < data.queueLimit ? 'bg-success' : 'bg-danger'}" style="width: ${queuePercent}%"></div></div>
                <hr style="border-color: rgba(255,255,255,0.1);">
                <div class="d-flex justify-content-between align-items-center mt-3 mb-2"><span class="text-muted fw-bold">Paid Conversion</span><span class="fw-bold text-info fs-5">${paidConversion}%</span></div>
                <div class="d-flex justify-content-between align-items-center mt-3"><span class="text-muted fw-bold">Fulfillment Success</span><span class="fw-bold text-success-custom fs-5">${fulfillmentSuccess}%</span></div>`;
        }

        function renderAiStatus(data) {
            const container = document.getElementById('ai-status-badges');
            if (!container) return;

            let html = data.isModelTrained
                ? `<span class="badge bg-success bg-opacity-25 text-success-custom border border-success badge-status"><i class="fa-solid fa-circle-check me-1"></i> MODEL ONLINE</span>`
                : `<span class="badge bg-danger bg-opacity-25 text-danger border border-danger badge-status"><i class="fa-solid fa-circle-xmark me-1"></i> OFFLINE (NEEDS DATA)</span>`;

            if (data.isModelTrained && data.activeMae !== null && data.activeMae !== undefined) {
                html += `<span class="badge bg-info bg-opacity-25 text-info border border-info badge-status">MAE: ${Number(data.activeMae).toFixed(3)}</span>`;
            }

            container.innerHTML = html;
            const predictButton = document.querySelector('form[action="/admin/ml/predict"] button');
            if (predictButton) predictButton.disabled = !data.isModelTrained;
        }

        function renderAiFeedback(data) {
            const feedback = document.getElementById('ai-feedback-area');
            const prediction = document.getElementById('prediction-result');
            if (!feedback || !prediction) return;

            if (data.error) {
                feedback.innerHTML = `<div class="alert alert-danger d-flex align-items-center rounded-3 shadow-sm border-0 bg-dark text-danger mb-4"><i class="fa-solid fa-triangle-exclamation me-3 fs-5"></i><div>${escapeHtml(data.error)}</div></div>`;
            } else if (data.isModelTrained && !data.prediction) {
                feedback.innerHTML = `<div class="alert alert-success d-flex align-items-center rounded-3 shadow-sm border border-success border-opacity-25 bg-dark text-success-custom mb-5 p-3"><div class="bg-success bg-opacity-25 p-2 rounded-circle me-3"><i class="fa-solid fa-microchip fs-5"></i></div><div><strong class="d-block">Model Active</strong><span>AI Model successfully trained and loaded into server memory. Ready for predictions.</span></div></div>`;
            } else {
                feedback.innerHTML = '';
            }

            prediction.innerHTML = data.prediction ? `<div class="mt-5 p-5 rounded-4 text-center border position-relative overflow-hidden" style="background: linear-gradient(135deg, rgba(59, 130, 246, 0.1), rgba(124, 58, 237, 0.1)); border-color: rgba(59, 130, 246, 0.3) !important;"><i class="fa-solid fa-robot position-absolute opacity-10" style="font-size: 15rem; right: -2rem; bottom: -2rem;"></i><h5 class="text-uppercase mb-3 text-info fw-bold letter-spacing-1"><i class="fa-solid fa-chart-column me-2"></i>Estimated Demand for ${escapeHtml(data.prediction.item)}</h5><div class="display-1 fw-bold text-white mb-2" style="text-shadow: 0 0 30px rgba(59,130,246,0.5);">${escapeHtml(data.prediction.demand)} <span class="fs-4 text-muted fw-normal">Plates</span></div><span class="badge bg-dark border border-secondary text-info px-3 py-2 rounded-pill shadow-sm"><i class="fa-solid fa-shield-halved me-1"></i> Includes a 5% safety buffer</span></div>` : '';
        }

        function renderMenuItems(data) {
            const heading = document.getElementById('menu-items-heading');
            const container = document.getElementById('menu-items-container');
            if (!heading || !container) return;

            heading.textContent = `Current Menu Items (${data.products.length})`;

            if (!data.products.length) {
                container.innerHTML = `<div class="text-center text-muted p-4 border border-secondary border-opacity-25 rounded-4 border-dashed"><i class="fa-solid fa-plate-wheat fs-1 mb-2 opacity-50"></i><p class="mb-0">Menu is empty.</p></div>`;
                return;
            }

            container.innerHTML = data.products.map((p) => `
                <div class="menu-item-card shadow-sm">
                    <div class="d-flex align-items-center gap-3">
                        ${p.imageUrl ? `<img src="${escapeHtml(p.imageUrl)}" alt="${escapeHtml(p.name)}" class="product-thumb shadow-sm">` : `<div class="product-thumb product-thumb-fallback shadow-sm"><i class="fa-solid fa-utensils"></i></div>`}
                        <div>
                            <strong class="text-white d-block fs-6 mb-1">${escapeHtml(p.name)}</strong>
                            <div class="d-flex align-items-center flex-wrap gap-2">
                                <span class="text-success-custom fw-bold">${rupee}${p.price}</span>
                                <span class="badge bg-dark border border-secondary text-muted" style="font-size: 0.65rem;">${escapeHtml(p.category || 'Other')}</span>
                                <span class="badge ${p.isAvailable ? 'bg-success bg-opacity-10 text-success border border-success border-opacity-25' : 'bg-secondary bg-opacity-10 text-secondary border border-secondary'}" style="font-size: 0.65rem;"><i class="fa-solid ${p.isAvailable ? 'fa-eye' : 'fa-eye-slash'} me-1"></i> ${p.isAvailable ? 'Vis' : 'Hid'}</span>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex flex-column gap-2 ms-2">
                        <form action="/admin/product/toggle-availability/${p._id}" method="POST" class="m-0"><button class="btn btn-sm w-100 ${p.isAvailable ? 'btn-outline-secondary text-muted' : 'btn-outline-success'} rounded-2" title="Toggle Visibility"><i class="fa-solid ${p.isAvailable ? 'fa-eye-slash' : 'fa-eye'}"></i></button></form>
                        <form action="/admin/product/delete/${p._id}" method="POST" class="m-0"><button class="btn btn-sm w-100 btn-outline-danger border-0 rounded-2 bg-danger bg-opacity-10" title="Delete Item"><i class="fa-solid fa-trash-can"></i></button></form>
                    </div>
                </div>`).join('');
        }

        function renderOrdersFromState(data) {
            const tbody = document.getElementById('live-orders-table');
            if (!tbody || !Array.isArray(data.orders)) return;

            tbody.innerHTML = data.orders.map((o) => {
                const itemsHtml = `<div class="bg-dark bg-opacity-50 p-2 rounded-3 border border-secondary border-opacity-25 mb-2"><ul class="mb-0 small ps-3 text-white">${o.items.map((i) => `<li><span class="text-danger fw-bold me-1">${i.quantity}x</span> ${escapeHtml(i.itemName)}</li>`).join('')}</ul></div><div class="fw-bold text-success-custom fs-5">${rupee}${o.totalAmount}</div>`;
                let statusBadge = `<span class="badge ${getStatusBadgeClass(o.status)} w-100 rounded-pill px-3 py-2 shadow-sm">${escapeHtml(o.status)}</span>`;

                if (o.couponCode && o.status !== 'Fulfilled') {
                    statusBadge += `<div class="mt-2 badge border border-info text-info bg-info bg-opacity-10 w-100 py-2 d-flex align-items-center justify-content-center" style="font-size: 0.85rem; letter-spacing: 1px;"><i class="fa-solid fa-ticket me-2"></i> ${escapeHtml(o.couponCode)}</div>`;
                }

                let actionButtons = '<div class="d-flex justify-content-end gap-2 action-buttons-wrap">';
                if (o.status !== 'Fulfilled' && o.status !== 'Rejected' && o.status !== 'Cancelled') {
                    actionButtons += o.paymentStatus !== 'Paid'
                        ? `<form action="/admin/order/coupon/${o._id}" method="POST" class="m-0 flex-grow-1 flex-sm-grow-0"><button class="btn btn-sm btn-info shadow-sm rounded-3 text-dark fw-bold w-100 h-100" title="Payment Received - Issue Coupon"><i class="fa-solid fa-ticket"></i> ISSUE</button></form>`
                        : `<form action="/admin/order/fulfill/${o._id}" method="POST" class="m-0 flex-grow-1 flex-sm-grow-0"><button class="btn btn-sm btn-success shadow-sm rounded-3 fw-bold w-100 h-100" title="Mark as Fulfilled"><i class="fa-solid fa-check"></i> FULFILL</button></form>`;
                    actionButtons += `<form action="/admin/order/reject/${o._id}" method="POST" class="m-0"><button class="btn btn-sm btn-warning-soft shadow-sm rounded-3 fw-bold h-100" title="Reject Order"><i class="fa-solid fa-ban"></i></button></form>`;
                }

                actionButtons += `<form action="/admin/order/delete/${o._id}" method="POST" class="m-0"><button class="btn btn-sm btn-outline-danger shadow-sm rounded-3 h-100" title="Delete Log"><i class="fa-solid fa-trash-can"></i></button></form></div>`;

                return `<tr><td class="ps-4"><strong class="text-white fs-6">${escapeHtml(o.studentName)}</strong><br><span class="small text-muted">${escapeHtml(o.year)} | ${escapeHtml(o.branch)}</span><br><span class="badge bg-dark border border-secondary text-muted mt-1 px-2 py-1">Reg: ${escapeHtml(o.regNo)}</span></td><td>${itemsHtml}</td><td class="text-center" style="width: 140px;">${statusBadge}</td><td class="pe-4">${actionButtons}</td></tr>`;
            }).join('');
        }

        function renderDashboardState(data, options = {}) {
            dashboardState = data;
            renderEventBadge(data.eventActive);
            renderAnalyticsSummary(data);
            renderTopItems(data);
            renderQuickHealth(data);
            renderMenuItems(data);
            renderAiStatus(data);
            renderOrdersFromState(data);
            if (options.includeAiFeedback !== false) {
                renderAiFeedback(data);
            }
        }

        async function fetchDashboardState() {
            const response = await fetch('/admin/api/dashboard', {
                headers: {
                    'Accept': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                }
            });
            const data = await response.json();
            if (!response.ok) {
                throw new Error(data.error || 'Failed to fetch dashboard state');
            }
            return data;
        }

        async function submitAdminForm(form) {
            const submitButton = form.querySelector('button[type="submit"], button:not([type])');
            const isTrainingForm = form.action.includes('/admin/ml/train');
            const isPredictionForm = form.action.includes('/admin/ml/predict');
            const originalButtonHtml = submitButton ? submitButton.innerHTML : '';
            const wasButtonDisabled = submitButton ? submitButton.disabled : false;
            if (submitButton) submitButton.disabled = true;

            if (isTrainingForm && submitButton) {
                submitButton.classList.add('training-pulse');
                submitButton.innerHTML = '<i class="fa-solid fa-spinner fa-spin me-2"></i> TRAINING MODEL...';
                renderAiFeedback({
                    ...dashboardState,
                    error: null,
                    prediction: null,
                    isModelTrained: false
                });
                const feedback = document.getElementById('ai-feedback-area');
                if (feedback) {
                    feedback.innerHTML = `
                        <div class="alert alert-info d-flex align-items-center rounded-3 shadow-sm border border-info border-opacity-25 bg-dark text-info mb-5 p-3">
                            <div class="bg-info bg-opacity-10 p-2 rounded-circle me-3"><i class="fa-solid fa-spinner fa-spin fs-5"></i></div>
                            <div>
                                <strong class="d-block">Training in Progress</strong>
                                <span>The model is buffering training data and learning patterns. Please wait a moment.</span>
                            </div>
                        </div>`;
                }
            }

            if (isPredictionForm && submitButton) {
                submitButton.classList.add('training-pulse');
                submitButton.innerHTML = '<i class="fa-solid fa-spinner fa-spin me-2"></i> GENERATING PREDICTION...';
                const feedback = document.getElementById('ai-feedback-area');
                const prediction = document.getElementById('prediction-result');

                if (feedback) {
                    feedback.innerHTML = `
                        <div class="alert alert-info d-flex align-items-center rounded-3 shadow-sm border border-info border-opacity-25 bg-dark text-info mb-5 p-3">
                            <div class="bg-info bg-opacity-10 p-2 rounded-circle me-3"><i class="fa-solid fa-spinner fa-spin fs-5"></i></div>
                            <div>
                                <strong class="d-block">Prediction in Progress</strong>
                                <span>The AI model is buffering your inputs and generating demand. Please wait a moment.</span>
                            </div>
                        </div>`;
                }

                if (prediction) {
                    prediction.innerHTML = `
                        <div class="mt-5 p-5 rounded-4 text-center border border-info border-opacity-25 bg-dark text-info">
                            <i class="fa-solid fa-spinner fa-spin fs-1 mb-3"></i>
                            <h5 class="text-uppercase fw-bold mb-1">Generating Prediction</h5>
                            <div class="text-muted">Processing model output...</div>
                        </div>`;
                }
            }

            try {
                const isMultipart = form.enctype === 'multipart/form-data';
                const body = isMultipart ? new FormData(form) : new URLSearchParams(new FormData(form));

                const response = await fetch(form.action, {
                    method: form.method || 'POST',
                    headers: {
                        'Accept': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body
                });

                const result = await response.json();
                if (!response.ok || !result.success) {
                    throw new Error(result.error || 'Request failed');
                }

                const nextState = result.dashboard || result;
                renderDashboardState(nextState, { includeAiFeedback: true });
                latestOrderId = nextState.orders?.[0]?._id || latestOrderId;

                if (form.action.includes('/admin/product/add') || form.action.includes('/admin/ml/train')) {
                    form.reset();
                }
            } catch (error) {
                console.error('Admin form submission failed:', error);
                if (dashboardState) {
                    renderAiFeedback({ ...dashboardState, error: error.message, prediction: dashboardState.prediction || null });
                }
            } finally {
                if (submitButton) {
                    submitButton.disabled = wasButtonDisabled;
                    submitButton.classList.remove('training-pulse');
                    submitButton.innerHTML = originalButtonHtml;
                }
            }
        }

        document.addEventListener('submit', (event) => {
            const form = event.target;
            if (!(form instanceof HTMLFormElement)) return;
            if (form.method.toUpperCase() !== 'POST') return;

            event.preventDefault();
            submitAdminForm(form);
        });

        renderDashboardState(dashboardState, { includeAiFeedback: true });
        setInterval(async () => {
            try {
                const freshState = await fetchDashboardState();
                renderDashboardState({ ...freshState, prediction: dashboardState?.prediction || null, error: dashboardState?.error || null }, { includeAiFeedback: false });
            } catch (error) {
                console.error('Dashboard sync failed:', error);
            }
        }, 5000);
    </script>

    <%- include('../layouts/footer') %>
