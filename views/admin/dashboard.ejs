                                                            <button class="btn btn-sm btn-info shadow-sm rounded-3 text-dark fw-bold h-100" title="Payment Received - Issue Coupon">
                                                                <i class="fa-solid fa-ticket"></i> ISSUE
                                                            </button>
                                                        </form>
                                                    <% } else { %>
                                                        <form action="/admin/order/fulfill/<%= o._id %>" method="POST" class="m-0">
                                                            <button class="btn btn-sm btn-success shadow-sm rounded-3 fw-bold h-100" title="Mark as Fulfilled">
