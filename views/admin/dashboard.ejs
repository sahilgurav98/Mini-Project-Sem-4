            </div>

            <div class="col-lg-4">
                <div class="card admin-card h-100 mb-0">
                    <div class="card-header admin-header-bg py-3 border-bottom-0">
                        <h5 class="mb-0 fw-bold text-white"><i class="fa-solid fa-burger me-2 text-warning"></i>Menu Manager</h5>
                    </div>
                    <div class="card-body pt-0 d-flex flex-column">
                        
                        <form action="/admin/product/add" method="POST" class="mb-4 bg-dark bg-opacity-50 p-4 rounded-4 border border-secondary border-opacity-25 shadow-sm">
