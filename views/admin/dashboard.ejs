                                                <div class="mt-2 badge border border-info text-info bg-info bg-opacity-10 w-100 py-2 d-flex align-items-center justify-content-center" style="font-size: 0.85rem; letter-spacing: 1px;">
                                                    <i class="fa-solid fa-ticket me-2"></i> <%= o.couponCode %>
