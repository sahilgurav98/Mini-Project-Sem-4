<%- include('layouts/header') %>

<style>
    :root {
        --shadow-accent: #7c3aed;      /* Electric Purple */
        --shadow-accent-glow: rgba(124, 58, 237, 0.4);
        --admin-accent: #dc2626;       /* Cyber Red */
        --admin-accent-glow: rgba(220, 38, 38, 0.4);
        --shadow-bg: #0b0f19;          /* Deep Dark Blue/Black */
        --shadow-card: #111827;        /* Dark Panel */
        --shadow-text: #f8fafc;
        --shadow-muted: #94a3b8;
        --grid-color: rgba(255, 255, 255, 0.03);
    }

    body {
        background-color: var(--shadow-bg);
        color: var(--shadow-text);
        /* High-tech grid background pattern */
        background-image: 
            linear-gradient(var(--grid-color) 1px, transparent 1px),
            linear-gradient(90deg, var(--grid-color) 1px, transparent 1px);
        background-size: 40px 40px;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        overflow-x: hidden;
    }

    /* Flex wrapper to ensure a 'filled' screen */
    .main-wrapper {
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
    }

    /* Hero Section */
    .hero-section {
        padding: 0rem 0 4rem;
        position: relative;
        z-index: 2;
    }

    /* Glowing Orb Behind Title */
    .glow-orb {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 350px;
        height: 350px;
        background: radial-gradient(circle, var(--shadow-accent-glow) 0%, transparent 70%);
        z-index: -1;
        filter: blur(45px);
        animation: pulse 4s infinite alternate;
    }

    @keyframes pulse {
        0% { transform: translate(-50%, -50%) scale(1); opacity: 0.5; }
        100% { transform: translate(-50%, -50%) scale(1.3); opacity: 1; }
    }

    /* Highly Responsive Title using Clamp */
    .main-title {
        font-weight: 900;
        letter-spacing: 2px;
        background: linear-gradient(to right, #fff, #a78bfa);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 0.5rem;
        /* Scales smoothly between 2.5rem (mobile) and 4.5rem (desktop) */
        font-size: clamp(2.5rem, 6vw, 4.5rem); 
    }

    .subtitle {
        color: #38bdf8;
        font-size: clamp(0.9rem, 2vw, 1.25rem);
        font-weight: 700;
        letter-spacing: 4px;
        text-transform: uppercase;
        max-width: 600px;
        margin: 0 auto 3rem;
    }

    /* Portal Cards */
    .portal-card {
        background-color: var(--shadow-card);
        border-radius: 1.25rem;
        padding: 3rem 2rem;
        height: 100%;
        border: 1px solid rgba(255, 255, 255, 0.05);
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        position: relative;
        overflow: hidden;
        z-index: 1;
    }

    .portal-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; height: 4px;
        z-index: 2;
    }

    .student-card::before { background: linear-gradient(90deg, #4c1d95, var(--shadow-accent)); }
    .admin-card::before { background: linear-gradient(90deg, #7f1d1d, var(--admin-accent)); }

    .portal-card:hover {
        transform: translateY(-10px);
    }

    .student-card:hover { box-shadow: 0 20px 40px var(--shadow-accent-glow); border-color: rgba(124, 58, 237, 0.3); }
    .admin-card:hover { box-shadow: 0 20px 40px var(--admin-accent-glow); border-color: rgba(220, 38, 38, 0.3); }

    .icon-wrapper {
        width: 80px;
        height: 80px;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
        font-size: 2.5rem;
    }

    .student-icon { background: rgba(124, 58, 237, 0.1); color: var(--shadow-accent); border: 1px solid rgba(124, 58, 237, 0.2); }
    .admin-icon { background: rgba(220, 38, 38, 0.1); color: var(--admin-accent); border: 1px solid rgba(220, 38, 38, 0.2); }

    /* Buttons */
    .btn-custom {
        padding: 0.8rem 2rem;
        border-radius: 0.75rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        transition: all 0.3s ease;
        width: 100%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
    }

    .btn-student {
        background-color: var(--shadow-accent);
        color: white;
        border: none;
    }
    .btn-student:hover { background-color: var(--shadow-accent-hover); color: white; box-shadow: 0 0 15px var(--shadow-accent-glow); }

    .btn-admin {
        background-color: transparent;
        color: var(--shadow-text);
        border: 1px solid rgba(255,255,255,0.2);
    }
    .btn-admin:hover { background-color: var(--admin-accent); border-color: var(--admin-accent); color: white; box-shadow: 0 0 15px var(--admin-accent-glow); }

    /* Tech Features Ribbon */
    .tech-ribbon {
        background: rgba(0, 0, 0, 0.6);
        border-top: 1px solid rgba(255,255,255,0.05);
        border-bottom: 1px solid rgba(255,255,255,0.05);
        padding: 2rem 0;
        margin-top: auto;
        backdrop-filter: blur(10px);
    }

    .feature-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        color: var(--shadow-muted);
    }
    
    .feature-item i {
        color: #38bdf8;
        font-size: 1.5rem;
    }

    /* Developer Credits */
    .credits-footer {
        text-align: center;
        padding: 1.5rem 1rem;
        color: var(--shadow-muted);
        font-size: 0.95rem;
        letter-spacing: 0.5px;
        background: rgba(0, 0, 0, 0.8);
        line-height: 1.6;
    }
    .dev-names {
        color: #f8fafc;
        font-weight: 700;
    }

    /* =========================================
       MOBILE & TABLET RESPONSIVENESS
       ========================================= */
       
    /* Desktop borders for the tech ribbon */
    @media (min-width: 768px) {
        .middle-feature {
            border-left: 1px solid rgba(255,255,255,0.05) !important;
            border-right: 1px solid rgba(255,255,255,0.05) !important;
        }
    }

    /* Mobile/Tablet overrides */
    @media (max-width: 767px) {
        .hero-section {
            padding: 2rem 0 3rem;
        }
        
        .glow-orb {
            width: 200px;
            height: 200px;
            filter: blur(35px);
        }

        .subtitle {
            letter-spacing: 2px; /* Prevent text clipping on narrow phones */
            margin-bottom: 2rem;
        }

        .portal-card {
            padding: 2rem 1.5rem; /* Slightly tighter padding on mobile */
        }
        
        /* Adjust Tech Ribbon for vertical stacking */
        .tech-ribbon {
            padding: 1rem 0;
        }
        
        .feature-item {
            justify-content: center; /* Center items on mobile */
        }

        .middle-feature {
            /* Switch vertical borders to horizontal borders when stacked */
            border-left: none !important;
            border-right: none !important;
            border-top: 1px solid rgba(255,255,255,0.05);
            border-bottom: 1px solid rgba(255,255,255,0.05);
            padding: 1.25rem 0;
            margin: 1.25rem 0;
        }
        
        .credits-footer {
            font-size: 0.85rem;
        }
    }
</style>

<div class="main-wrapper">
    <div class="glow-orb"></div>
    
    <div class="hero-section text-center">
        <div class="container">
            <div class="d-inline-block mb-3 mb-md-4">
                <span class="badge rounded-pill border border-secondary px-3 py-2 text-info" style="background: rgba(0,0,0,0.5); letter-spacing: 1px;">
                    <i class="fa-solid fa-microchip me-1"></i> POWERED BY FNN AI MODEL
                </span>
            </div>

            <h1 class="main-title">CANTEEN DAMS</h1>
            <p class="subtitle">Demand & Management System</p>

            <div class="row justify-content-center g-4 mt-2">
                
                <div class="col-md-5 col-lg-4">
                    <div class="portal-card student-card text-center">
                        <div class="icon-wrapper student-icon">
                            <i class="fa-solid fa-user-graduate"></i>
                        </div>
                        <h3 class="fw-bold mb-3 text-white">Student Portal</h3>
                        <p class="text-white opacity-75 small mb-4" style="line-height: 1.6;">Skip the lines. Browse the live menu, place orders asynchronously, and track your food status in real-time.</p>
                        <a href="/auth/login/student" class="btn btn-custom btn-student">
                            Access Portal <i class="fa-solid fa-arrow-right"></i>
                        </a>
                    </div>
                </div>

                <div class="col-md-5 col-lg-4">
                    <div class="portal-card admin-card text-center">
                        <div class="icon-wrapper admin-icon">
                            <i class="fa-solid fa-server"></i>
                        </div>
                        <h3 class="fw-bold mb-3 text-white">Admin Dashboard</h3>
                        <p class="text-white opacity-75 small mb-4" style="line-height: 1.6;">Manage live inventory, fulfill incoming orders, and run demand forecasting using the built-in Machine Learning engine.</p>
                        <a href="/auth/login/admin" class="btn btn-custom btn-admin">
                            System Login <i class="fa-solid fa-terminal"></i>
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <div class="tech-ribbon w-100">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-md-4 d-flex justify-content-center align-items-center">
                    <div class="feature-item">
                        <i class="fa-solid fa-bolt"></i>
                        <div class="text-start">
                            <strong class="d-block text-white">AJAX Asynchronous</strong>
                            <span class="small">Zero-reload order processing</span>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 d-flex justify-content-center align-items-center middle-feature">
                    <div class="feature-item">
                        <i class="fa-solid fa-brain"></i>
                        <div class="text-start">
                            <strong class="d-block text-white">TensorFlow.js Engine</strong>
                            <span class="small">In-memory demand prediction</span>
                        </div>
                    </div>
                </div>
                <div class="col-md-4 d-flex justify-content-center align-items-center">
                    <div class="feature-item">
                        <i class="fa-solid fa-shield-halved"></i>
                        <div class="text-start">
                            <strong class="d-block text-white">Encrypted Sessions</strong>
                            <span class="small">Bcrypt password hashing</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="credits-footer w-100">
    Developed by: <span class="dev-names">Sahil Gurav, Kanva Deolekar, Harshwardhan Jadhav, Sujal Bondkar</span>
</div>
<button id="chatbot-toggle" class="btn btn-primary shadow-lg d-flex justify-content-center align-items-center" onclick="toggleChat()">
    <i class="fa-solid fa-robot fa-lg"></i>
</button>

<div id="chatbot-window" class="shadow-lg">
    <div class="chat-header d-flex justify-content-between align-items-center">
        <div>
            <i class="fa-solid fa-microchip me-2 text-info"></i>
            <span class="fw-bold">CDMS AI Assistant</span>
        </div>
        <button class="btn btn-sm text-white border-0 bg-transparent" onclick="toggleChat()">
            <i class="fa-solid fa-xmark fa-lg"></i>
        </button>
    </div>
    
    <div id="chat-body" class="chat-body p-3">
        <div class="bot-message mb-3">
            Hello! I am the Canteen DAMS AI Assistant. 🤖<br><br>
            
            How can I help you today?
        </div>
    </div>
    
    <div class="chat-footer p-2 border-top border-secondary d-flex bg-dark">
        <input type="text" id="chat-input" class="form-control form-control-sm bg-dark text-white border-secondary me-2" placeholder="Type your question here..." autocomplete="off" onkeypress="handleEnter(event)">
        <button class="btn btn-sm btn-info fw-bold d-flex justify-content-center align-items-center px-3" onclick="sendMessage()">
            <i class="fa-solid fa-paper-plane"></i>
        </button>
    </div>
</div>

<style>
    /* Chatbot Button Default (Desktop) */
    #chatbot-toggle {
        position: fixed;
        bottom: 30px;
        right: 30px;
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: var(--shadow-accent, #7c3aed);
        border: none;
        z-index: 9999;
        transition: transform 0.3s ease;
        box-shadow: 0 0 20px rgba(124, 58, 237, 0.5);
    }
    
    #chatbot-toggle:hover {
        transform: scale(1.1);
        background: #6d28d9;
    }

    /* Chatbot Window Default (Desktop) */
    #chatbot-window {
        position: fixed;
        bottom: 100px;
        right: 30px;
        width: 380px;
        height: 500px;
        background: #1e1e2f;
        border: 1px solid rgba(124, 58, 237, 0.3);
        border-radius: 15px;
        display: none; 
        flex-direction: column;
        z-index: 9999;
        overflow: hidden;
        box-shadow: 0 10px 40px rgba(0,0,0,0.8);
    }

    /* --- RESPONSIVE MEDIA QUERIES --- */
    /* Adjusts for Mobile Phones */
    @media (max-width: 576px) {
        #chatbot-window {
            width: 90vw; /* 90% of screen width */
            height: 70vh; /* 70% of screen height */
            right: 5vw;   /* Center it slightly */
            bottom: 90px;
        }
        
        #chatbot-toggle {
            bottom: 20px;
            right: 20px;
            width: 55px;
            height: 55px;
        }
    }

    /* Adjusts for very small phones */
    @media (max-width: 380px) {
        #chatbot-window {
            width: 95vw;
            right: 2.5vw;
        }
    }
    /* -------------------------------- */

    .chat-header {
        background: rgba(0, 0, 0, 0.6);
        padding: 15px;
        border-bottom: 1px solid rgba(124, 58, 237, 0.3);
        color: white;
    }

    .chat-body {
        flex-grow: 1;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 10px;
        background: #1e1e2f;
    }

    .chat-body::-webkit-scrollbar { width: 6px; }
    .chat-body::-webkit-scrollbar-thumb { background: #7c3aed; border-radius: 3px; }

    .bot-message {
        background: rgba(124, 58, 237, 0.15);
        border-left: 3px solid #7c3aed;
        padding: 12px 15px;
        border-radius: 0 12px 12px 12px;
        font-size: 0.9rem;
        color: #e2e8f0;
        max-width: 90%;
        align-self: flex-start;
        line-height: 1.5;
    }

    .user-message {
        background: rgba(56, 189, 248, 0.15);
        border-right: 3px solid #38bdf8;
        padding: 10px 15px;
        border-radius: 12px 0 12px 12px;
        font-size: 0.9rem;
        color: #e2e8f0;
        max-width: 85%;
        align-self: flex-end;
        line-height: 1.4;
    }
</style>

<script>
    function toggleChat() {
        const chatWindow = document.getElementById('chatbot-window');
        chatWindow.style.display = chatWindow.style.display === 'flex' ? 'none' : 'flex';
        
        // Auto-focus input when opened on desktop
        if (chatWindow.style.display === 'flex' && window.innerWidth > 576) {
            document.getElementById('chat-input').focus();
        }
    }

    function handleEnter(event) {
        if (event.key === 'Enter') sendMessage();
    }

    async function sendMessage() {
        const inputField = document.getElementById('chat-input');
        const userText = inputField.value.trim();
        if (!userText) return;

        appendMessage(userText, 'user-message');
        inputField.value = '';

        // Added loading indicator
        const loadingDiv = document.createElement('div');
        loadingDiv.className = 'bot-message mb-3 shadow-sm';
        loadingDiv.id = 'chat-loading';
        loadingDiv.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Thinking...';
        const chatBody = document.getElementById('chat-body');
        chatBody.appendChild(loadingDiv);
        chatBody.scrollTop = chatBody.scrollHeight;

        try {
            const response = await fetch('/api/chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message: userText })
            });
            const data = await response.json();
            
            const loadingEl = document.getElementById('chat-loading');
            if (loadingEl) loadingEl.remove();

            appendMessage(data.reply, 'bot-message');
        } catch (error) {
            console.error("Chat error:", error);
            const loadingEl = document.getElementById('chat-loading');
            if (loadingEl) loadingEl.remove();
            appendMessage("Sorry, I'm having trouble connecting to the server.", 'bot-message');
        }
    }

    function appendMessage(text, className) {
        const chatBody = document.getElementById('chat-body');
        const messageDiv = document.createElement('div');
        messageDiv.className = className + ' mb-3 shadow-sm';
        
        // Basic Markdown replacement: Bold and Newlines
        let formattedText = text.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
        formattedText = formattedText.replace(/\*(.*?)\*/g, '<em>$1</em>');
        formattedText = formattedText.replace(/\n/g, '<br>');
        
        messageDiv.innerHTML = formattedText;
        chatBody.appendChild(messageDiv);
        chatBody.scrollTop = chatBody.scrollHeight;
    }
</script>

<%- include('layouts/footer') %>