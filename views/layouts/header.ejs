<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Canteen System</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <link rel="stylesheet" href="/css/style.css">

    <style>
        /* Global Dark Theme Variables - Applies to all pages using this header */
        :root {
            --shadow-accent: #7c3aed;
            /* Electric Purple */
            --shadow-accent-hover: #6d28d9;
            --shadow-bg: #0b0f19;
            /* Very dark blue/black */
            --shadow-card: #111827;
            /* Dark gray */
            --shadow-text: #f3f4f6;
            --shadow-muted: #9ca3af;
            --shadow-border: rgba(255, 255, 255, 0.08);
        }

        /* Set the global background color */
        body {
            background-color: var(--shadow-bg);
            color: var(--shadow-text);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Navbar Customization */
        .navbar-custom {
            background-color: var(--shadow-card);
            border-bottom: 1px solid var(--shadow-border);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
            padding: 1rem 0;
        }

        .navbar-brand-custom {
            color: var(--shadow-text) !important;
            font-weight: 800;
            letter-spacing: 1px;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            transition: transform 0.3s ease;
        }

        .navbar-brand-custom:hover {
            transform: translateY(-1px);
        }

        .brand-icon-wrapper {
            background: linear-gradient(135deg, #4c1d95, #7c3aed);
            width: 36px;
            height: 36px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 10px rgba(124, 58, 237, 0.3);
        }

        .brand-icon-wrapper i {
            color: white;
            font-size: 1.1rem;
        }

        /* User Profile & Logout */
        .user-greeting {
            color: var(--shadow-muted);
            font-weight: 500;
        }

        .user-name-highlight {
            color: white;
            font-weight: 700;
            letter-spacing: 0.5px;
        }

        .btn-logout {
            color: var(--shadow-text);
            border: 1px solid var(--shadow-border);
            background: rgba(255, 255, 255, 0.03);
            border-radius: 0.5rem;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .btn-logout:hover {
            background-color: rgba(239, 68, 68, 0.1);
            /* Subtle red tint on hover */
            border-color: #ef4444;
            /* Red border */
            color: #ef4444;
            transform: translateY(-1px);
        }

        /* Flex grow wrapper to push the footer down if you have one */
        .main-content-wrapper {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
        }
    </style>
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-custom sticky-top">
        <div class="container-fluid px-4">

            <a class="navbar-brand navbar-brand-custom text-decoration-none" href="/">
                <div class="brand-icon-wrapper">
                    <i class="fa-solid fa-layer-group"></i>
                </div>
                <span>CANTEEN <span style="color: var(--shadow-accent);">DAMS</span></span>
            </a>

            <% if (user) { %>
                <div class="d-flex align-items-center gap-3 gap-md-4 ms-auto">

                    <div class="user-greeting d-none d-sm-flex align-items-center">
                        <i class="fa-solid fa-circle-user fs-5 me-2" style="color: var(--shadow-accent);"></i>
                        <span>Welcome, <span class="user-name-highlight">
                                <%= user.name || user.username %>
                            </span></span>
                    </div>

                    <a href="/auth/logout" class="btn btn-sm btn-logout px-3 py-2 fw-bold shadow-sm">
                        <span>Logout</span>
                        <i class="fa-solid fa-power-off"></i>
                    </a>
                </div>
                <% } %>

        </div>
    </nav>

    <div class="main-content-wrapper">
        <div class="container py-4 flex-grow-1">