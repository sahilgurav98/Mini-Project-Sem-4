<%- include('../layouts/header') %>
<style>
    /* Reuse the exact same CSS variables from login/signup */
    :root { --shadow-accent: #7c3aed; --shadow-bg: #0b0f19; --shadow-card: #111827; --shadow-text: #f3f4f6; --shadow-muted: #9ca3af; }
    body { background-color: var(--shadow-bg); color: var(--shadow-text); }
    .form-control, .input-group-text { background-color: rgba(255, 255, 255, 0.03); border-color: rgba(255, 255, 255, 0.1); color: var(--shadow-text); }
    .form-control:focus { background-color: rgba(255, 255, 255, 0.05); box-shadow: 0 0 0 0.25rem rgba(124, 58, 237, 0.25); border-color: var(--shadow-accent); color: white;}
    .btn-primary { background-color: var(--shadow-accent); border-color: var(--shadow-accent); color: white; }
</style>

<div class="container my-5 d-flex align-items-center" style="min-height: 70vh;">
    <div class="row justify-content-center w-100">
        <div class="col-12 col-md-8 col-lg-5">
            <div class="card shadow-lg border-0" style="background-color: var(--shadow-card); border-radius: 1rem;">
                <div class="card-header text-center py-4 text-white border-0" style="background: linear-gradient(135deg, #4c1d95, #7c3aed); border-radius: 1rem 1rem 0 0;">
                    <i class="fa-solid fa-unlock-keyhole fa-3x mb-2"></i>
                    <h4 class="mb-0 fw-bold">RESET PASSWORD</h4>
                </div>
                <div class="card-body p-4 p-md-5">
                    <% if(error) { %><div class="alert alert-danger"><%= error %></div><% } %>
                    
                    <form action="/auth/reset-password" method="POST">
                        <div class="mb-4">
                            <label class="fw-bold small text-uppercase text-muted mb-2">Registered Email</label>
                            <div class="input-group">
                                <span class="input-group-text border-end-0"><i class="fa-solid fa-envelope"></i></span>
                                <input type="email" name="email" id="resetEmail" class="form-control border-start-0 ps-0" required>
                                <button class="btn btn-primary fw-bold" type="button" id="otpBtn" onclick="requestResetOTP()">Send OTP</button>
                            </div>
                            <div id="otpFeedback" class="small mt-2 d-none fw-bold"></div>
                        </div>

                        <div id="resetSection" class="d-none">
                            <div class="mb-3">
                                <label class="fw-bold small text-uppercase text-warning mb-2">Enter OTP</label>
                                <input type="text" name="otp" id="resetOtp" class="form-control text-warning fw-bold" maxlength="6">
                            </div>
                            <div class="mb-4">
                                <label class="fw-bold small text-uppercase text-muted mb-2">New Password</label>
                                <input type="password" name="newPassword" id="newPassword" class="form-control" placeholder="••••••••">
                            </div>
                            <button type="submit" class="btn btn-primary w-100 fw-bold shadow-sm">UPDATE PASSWORD</button>
                        </div>
                    </form>
                    <div class="text-center mt-4">
                        <a href="/auth/login/student" class="text-decoration-none text-muted fw-bold">&larr; Back to Login</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    async function requestResetOTP() {
        const email = document.getElementById('resetEmail').value;
        const btn = document.getElementById('otpBtn');
        const feedback = document.getElementById('otpFeedback');
        
        if(!email) return alert("Please enter your email first.");

        btn.disabled = true;
        btn.innerHTML = 'Sending...';

        try {
            const response = await fetch('/auth/send-reset-otp', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email })
            });
            const data = await response.json();

            if (data.success) {
                document.getElementById('resetSection').classList.remove('d-none');
                document.getElementById('resetOtp').required = true;
                document.getElementById('newPassword').required = true;
                
                feedback.innerHTML = '<i class="fa-solid fa-circle-check"></i> ' + data.message;
                feedback.className = 'small mt-2 fw-bold text-success';
                btn.innerHTML = 'Sent';
                document.getElementById('resetEmail').readOnly = true;
            } else {
                btn.disabled = false;
                btn.innerHTML = 'Send OTP';
                feedback.innerHTML = '<i class="fa-solid fa-circle-xmark"></i> ' + data.message;
                feedback.className = 'small mt-2 fw-bold text-danger';
            }
        } catch (err) {
            btn.disabled = false;
            btn.innerHTML = 'Send OTP';
        }
    }
</script>
<%- include('../layouts/footer') %>