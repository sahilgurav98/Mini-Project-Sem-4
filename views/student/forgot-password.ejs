<%- include('../layouts/header') %>

    <style>
        :root {
            --shadow-accent: #7c3aed;
            --shadow-accent-hover: #6d28d9;
            --shadow-bg: #0b0f19;
            --shadow-card: #111827;
            --shadow-text: #f8fafc;
            /* Brighter white */
            --shadow-muted: #cbd5e1;
            /* Lighter gray for readability */
            --shadow-border: rgba(255, 255, 255, 0.15);
        }

        body {
            background-color: var(--shadow-bg);
            color: var(--shadow-text) !important;
        }

        /* Fixed Input Visibility */
        .form-control,
        .input-group-text {
            background-color: rgba(0, 0, 0, 0.4) !important;
            border: 1px solid var(--shadow-border) !important;
            color: #ffffff !important;
        }

        .form-control:focus {
            background-color: rgba(0, 0, 0, 0.6) !important;
            box-shadow: 0 0 0 0.25rem rgba(124, 58, 237, 0.25) !important;
            border-color: var(--shadow-accent) !important;
            color: #ffffff !important;
        }

        /* Fixed Placeholder Visibility */
        .form-control::placeholder {
            color: rgba(255, 255, 255, 0.5) !important;
            opacity: 1;
        }

        .input-group-text i {
            color: var(--shadow-muted) !important;
        }

        .input-group:focus-within .input-group-text i {
            color: var(--shadow-accent) !important;
            transition: color 0.3s ease;
        }

        /* Custom Buttons */
        .btn-primary {
            background-color: var(--shadow-accent) !important;
            border-color: var(--shadow-accent) !important;
            color: white !important;
        }

        .btn-primary:hover {
            background-color: var(--shadow-accent-hover) !important;
            border-color: var(--shadow-accent-hover) !important;
        }

        .text-muted {
            color: var(--shadow-muted) !important;
        }

        /* Custom OTP Input Styling */
        #resetOtp {
            letter-spacing: 0.75rem;
            font-size: 1.5rem;
            text-align: center;
            color: #f59e0b !important;
            /* Bright amber color */
        }

        #resetOtp:focus {
            border-color: #f59e0b !important;
            box-shadow: 0 0 0 0.25rem rgba(245, 158, 11, 0.25) !important;
        }

        /* Smooth reveal for the hidden section */
        #resetSection {
            animation: fadeInDown 0.4s ease-out forwards;
        }

        @keyframes fadeInDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>

    <div class="container my-5 d-flex align-items-center" style="min-height: 70vh;">
        <div class="row justify-content-center w-100">
            <div class="col-12 col-md-8 col-lg-5">
                <div class="card shadow-lg border-0" style="background-color: var(--shadow-card); border-radius: 1rem;">

                    <div class="card-header text-center py-4 text-white border-0"
                        style="background: linear-gradient(135deg, #4c1d95, #7c3aed); border-radius: 1rem 1rem 0 0;">
                        <i class="fa-solid fa-unlock-keyhole fa-3x mb-3"></i>
                        <h4 class="mb-0 fw-bold" style="letter-spacing: 1px;">RESET PASSWORD</h4>
                    </div>

                    <div class="card-body p-4 p-md-5">
                        <% if(error) { %>
                            <div
                                class="alert alert-danger d-flex align-items-center rounded-3 fw-bold shadow-sm border-0 bg-dark text-danger">
                                <i class="fa-solid fa-triangle-exclamation me-2"></i>
                                <%= error %>
                            </div>
                            <% } %>

                                <form action="/auth/reset-password" method="POST">

                                    <div class="mb-4">
                                        <label class="fw-bold small text-uppercase text-muted mb-2">Registered
                                            Email</label>
                                        <div class="input-group input-group-lg shadow-sm">
                                            <span class="input-group-text border-end-0"><i
                                                    class="fa-solid fa-envelope"></i></span>
                                            <input type="email" name="email" id="resetEmail"
                                                class="form-control border-start-0 ps-0" placeholder="student@mu.ac.in"
                                                required>
                                            <button class="btn btn-primary fw-bold px-3 px-sm-4" type="button"
                                                id="otpBtn" onclick="requestResetOTP()">Send OTP</button>
                                        </div>
                                        <div id="otpFeedback" class="small mt-2 d-none fw-bold"></div>
                                    </div>

                                    <div id="resetSection" class="d-none pt-3 border-top"
                                        style="border-color: var(--shadow-border) !important;">
                                        <div class="mb-4">
                                            <label class="fw-bold small text-uppercase mb-2" style="color: #f59e0b;"><i
                                                    class="fa-solid fa-shield-halved me-1"></i> Enter 6-Digit
                                                OTP</label>
                                            <input type="text" name="otp" id="resetOtp"
                                                class="form-control form-control-lg shadow-sm fw-bold" maxlength="6"
                                                placeholder="------">
                                        </div>

                                        <div class="mb-4">
                                            <label class="fw-bold small text-uppercase text-muted mb-2">Create New
                                                Password</label>
                                            <div class="input-group input-group-lg shadow-sm">
                                                <span class="input-group-text border-end-0"><i
                                                        class="fa-solid fa-lock"></i></span>
                                                <input type="password" name="newPassword" id="newPassword"
                                                    class="form-control border-start-0 ps-0" placeholder="••••••••">
                                            </div>
                                        </div>

                                        <div class="mb-5">
                                            <label class="fw-bold small text-uppercase text-muted mb-2">Confirm New
                                                Password</label>
                                            <div class="input-group input-group-lg shadow-sm">
                                                <span class="input-group-text border-end-0"><i
                                                        class="fa-solid fa-lock"></i></span>
                                                <input type="password" name="confirmPassword" id="confirmPassword"
                                                    class="form-control border-start-0 ps-0" placeholder="••••••••">
                                            </div>
                                        </div>

                                        <button type="submit"
                                            class="btn btn-primary btn-lg w-100 fw-bold shadow-sm d-flex justify-content-center align-items-center gap-2">
                                            <i class="fa-solid fa-floppy-disk"></i>
                                            <span>UPDATE PASSWORD</span>
                                        </button>
                                    </div>

                                </form>

                                <div class="text-center mt-4 pt-3 border-top"
                                    style="border-color: var(--shadow-border) !important;">
                                    <a href="/auth/login/student"
                                        class="text-decoration-none text-muted fw-bold hover-white transition-all">
                                        &larr; Back to Login
                                    </a>
                                </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        async function requestResetOTP() {
            const email = document.getElementById('resetEmail').value;
            const btn = document.getElementById('otpBtn');
            const feedback = document.getElementById('otpFeedback');

            if (!email) return alert("Please enter your email first.");

            btn.disabled = true;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';

            try {
                const response = await fetch('/auth/send-reset-otp', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email })
                });
                const data = await response.json();

                if (data.success) {
                    // Reveal the hidden section smoothly
                    document.getElementById('resetSection').classList.remove('d-none');
                    document.getElementById('resetOtp').required = true;
                    document.getElementById('newPassword').required = true;
                    document.getElementById('confirmPassword').required = true;

                    feedback.innerHTML = '<i class="fa-solid fa-circle-check"></i> ' + data.message;
                    feedback.className = 'small mt-2 fw-bold text-success d-block';
                    btn.innerHTML = '<i class="fa-solid fa-check"></i> Sent';

                    // Lock the email input so they don't change it after requesting
                    document.getElementById('resetEmail').readOnly = true;
                    document.getElementById('resetEmail').style.opacity = '0.7';
                } else {
                    btn.disabled = false;
                    btn.innerHTML = 'Send OTP';
                    feedback.innerHTML = '<i class="fa-solid fa-circle-xmark"></i> ' + data.message;
                    feedback.className = 'small mt-2 fw-bold text-danger d-block';
                }
            } catch (err) {
                btn.disabled = false;
                btn.innerHTML = 'Send OTP';
            }
        }
    </script>

    <%- include('../layouts/footer') %>